{
  "name": "StaffNow – Βρες Προσωπικό Τουρισμού & Εστίασης",
  "short_name": "StaffNow",
  "description": "Swipe-style αντιστοίχιση εργαζομένων & επιχειρήσεων στον τουρισμό και την εστίαση. Βρες προσωπικό σε λίγα λεπτά.",
  "lang": "el",
  "dir": "ltr",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0A0F2E",
  "theme_color": "#3B82F6",
